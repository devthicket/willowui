        "cyanMid": "#00AAC0",
        "cyanDim": "#006878",
        "cyanDark": "#003844",
        "cyanDeep": "#001820",
        "cyanDeepMid": "#002430",
        "cyanDeepHover": "#004858",
        "cyanDeepActive": "#001418",
        "magenta": "#FF00CC",
        "magentaBright": "#FF44DD",
        "magentaMid": "#CC0099",
        "magentaDim": "#880066",
        "magentaDark": "#440033",
        "magentaDeep": "#220018",
        "magentaDeepMid": "#330022",
        "magentaDeepHover": "#580044",
        "magentaDeepActive": "#1A0010",
        "magentaBorder": "rgba(255, 0, 204, 0.5)",
        "neonGreen": "#39FF14",
        "neonGreenMid": "#28BB10",
        "neonGreenDark": "#186808",
        "red": "#FF2222",
        "redBright": "#FF5555",
        "redMid": "#CC1111",
        "redDark": "#660808",
        "redBg": "#440808",
        "redBgDark": "#220404",
        "redBgHover": "#580C0C",
        "redBgHoverDark": "#330606",
        "redBgActive": "#1A0303",
