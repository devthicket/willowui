                "cornerRadius": 3,
                "thumbBackgroundColor": {
                    "default": "$cyanDark",
                    "hover": "$cyanDim",
                    "active": "$cyanMid",
                    "disabled": "$disabledFg"
                },
                "thumbBorderColor": {
                    "default": "$border",
                    "hover": "$cyan",
                    "disabled": "$disabled"
                },
                "thumbCornerRadius": 2
            }
        },
        "meterBar": {
            "primary": {
                "backgroundColor": {
                    "default": "$surface"
                },
                "borderColor": {
                    "default": "$border"
