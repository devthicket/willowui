        "_": {
            "borderWidth": 1,
            "cornerRadius": 2,
            "focusColor": {
                "focus": "$cyan"
            },
            "focusRingWidth": 2
        },
        "button": {
            "_": {
                "cornerRadius": 3,
                "borderWidth": 1,
                "padding": {
                    "top": 6,
                    "right": 14,
                    "bottom": 6,
                    "left": 14
                },
                "offsetY": {
                    "default": 0,
                    "hover": -1,
                    "active": 2
                }
            },
            "primary": {
                "backgroundColor": {
                    "default": "gradientV($cyanDark, $cyanDeep)",
                    "hover": "gradientV($cyanDeepHover, $cyanDeepMid)",
                    "active": "$cyanDeepActive",
                    "disabled": "$disabled"
                },
                "textColor": {
                    "default": "$cyan",
                    "hover": "$cyanBright",
                    "active": "$cyanMid",
                    "disabled": "$disabledFg"
                },
                "borderColor": {
                    "default": "$border",
                    "hover": "$borderBright",
                    "focus": "$borderBright"
                }
            },
            "accent": {
                "backgroundColor": {
                    "default": "gradientV($magentaDark, $magentaDeep)",
                    "hover": "gradientV($magentaDeepHover, $magentaDeepMid)",
                    "active": "$magentaDeepActive",
                    "disabled": "$disabled"
                },
                "textColor": {
                    "default": "$magenta",
                    "hover": "$magentaBright",
                    "active": "$magentaMid",
                    "disabled": "$disabledFg"
                },
                "borderColor": {
                    "default": "$magentaBorder",
                    "hover": "$magenta",
                    "focus": "$magenta"
                }
            },
            "danger": {
                "backgroundColor": {
                    "default": "gradientV($redBg, $redBgDark)",
                    "hover": "gradientV($redBgHover, $redBgHoverDark)",
                    "active": "$redBgActive",
                    "disabled": "$disabled"
                },
                "textColor": {
                    "default": "$red",
                    "hover": "$redBright",
                    "active": "$redMid",
                    "disabled": "$disabledFg"
                },
                "borderColor": {
                    "default": "$redBorder",
                    "hover": "$red"
                }
            }
        },
        "label": {
            "primary": {
                "textColor": {
                    "default": "$fg",
                    "disabled": "$disabledFg"
                }
            },
            "heading": {
                "textColor": {
                    "default": "$cyan"
                }
            },
            "muted": {
                "textColor": {
                    "default": "$fgMuted",
                    "disabled": "$disabledFg"
                }
            }
        },
        "toggle": {
            "primary": {
                "trackColor": {
                    "default": "$surfaceBright",
                    "hover": "$magentaDark",
                    "active": "$magentaDim",
                    "focus": "$surfaceBright",
                    "focusActive": "$magentaDim",
                    "disabled": "$disabled"
                },
                "thumbColor": {
                    "default": "$fgMuted",
                    "active": "$magenta",
                    "disabled": "$disabledFg"
                },
                "cornerRadius": 7
            }
        },
        "checkbox": {
            "primary": {
                "boxColor": {
                    "default": "$surfaceLight",
                    "hover": "$surfaceBright",
                    "focus": "$surfaceLight",
                    "focusActive": "$cyan",
                    "disabled": "$disabled"
                },
                "checkColor": {
                    "default": "$cyan",
                    "disabled": "$disabledFg"
                }
            }
        },
        "radio": {
            "primary": {
                "circleColor": {
                    "default": "$surfaceLight",
                    "hover": "$surfaceBright",
                    "focus": "$surfaceLight",
                    "focusActive": "$magenta",
                    "disabled": "$disabled"
                },
                "dotColor": {
                    "default": "$magenta",
                    "disabled": "$disabledFg"
                }
